[user]
	email = reanpuhalovich@gmail.com
	name = Ryan Puhalovich
[init]
	defaultBranch = main
[core]
	editor = nvim
[advice]
	detachedHead = false
[diff]
	tool = vimdiff
[difftool]
	prompt = false
	trustExitCode = true
[alias]
	a = add .
	b = branch -a
	bl = blame
	c = commit
	ch = checkout
	clone = clone --recursive
	d = difftool
	dns = diff --name-status
	fetch = fetch --prune --all
	l = log
	lg = log --graph --topo-order --abbrev-commit --date=short --decorate --all --boundary --pretty=format:'%C(bold blue)<%cn> %Cgreen%ad %Cred%h%Creset -%C(yellow)%d%Creset %s %Creset'
	lo = log --oneline
	lt = log --tags --no-walk --pretty=oneline --abbrev-commit
	pull = pull --prune --all
	s = status
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential]
	helper = osxkeychain
